<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Cozy Bakery+</title>
<style>
  :root{
    --bg:#ffffff;
    --card:#ffffff;
    --ink:#1f1f1f;
    --muted:#666;
    --shadow:0 12px 30px rgba(0,0,0,.08);
    --shadow2:0 20px 45px rgba(0,0,0,.12);
    --soft:24px;
  }

  *{
    box-sizing:border-box;
    margin:0;
    padding:0;
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  }

  html,body{
    width:100%;
    height:100%;
    background:var(--bg);
    overflow:hidden;
    cursor:none;
  }

  body, body *{
    cursor:none !important;
  }

  .game{
    width:min(92vw, 420px);
    margin:36px auto 0;
    user-select:none;
    perspective:1000px;
  }

  .header{
    display:flex;
    justify-content:space-between;
    gap:12px;
    margin-bottom:18px;
  }

  .box{
    flex:1;
    padding:12px 16px;
    border-radius:999px;
    background:#fff;
    box-shadow:var(--shadow);
    color:var(--ink);
    font-size:14px;
    font-weight:700;
    letter-spacing:.2px;
    text-align:center;
  }

  .grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:14px;
  }

  .card{
    height:128px;
    border-radius:26px;
    background:var(--card);
    box-shadow:var(--shadow);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:34px;
    position:relative;
    transform-style:preserve-3d;
    transition:
      transform .22s cubic-bezier(.2,.9,.2,1),
      box-shadow .22s ease,
      scale .22s ease;
    will-change:transform;
    user-select:none;
  }

  .card:hover{
    box-shadow:var(--shadow2);
  }

  .card.correct{
    animation:pop .38s ease;
  }

  .card.wrong{
    animation:shake .34s ease;
  }

  @keyframes pop{
    0%{ transform:scale(1); }
    50%{ transform:scale(1.12); }
    100%{ transform:scale(1); }
  }

  @keyframes shake{
    0%,100%{ transform:translateX(0); }
    25%{ transform:translateX(-4px); }
    75%{ transform:translateX(4px); }
  }

  .fact{
    position:fixed;
    right:18px;
    bottom:-8vh;
    width:min(82vw, 540px);
    height:50vh;
    border-radius:34px 34px 26px 26px;
    background:#fff;
    box-shadow:0 25px 60px rgba(0,0,0,.18);
    padding:24px 26px 30px;
    display:flex;
    flex-direction:column;
    justify-content:flex-start;
    gap:18px;
    overflow:hidden;
    animation:slideUp .34s cubic-bezier(.18,.9,.22,1);
    z-index:50;
  }

  .fact .label{
    font-size:12px;
    font-weight:800;
    letter-spacing:.18em;
    color:var(--muted);
    text-transform:uppercase;
  }

  .fact .text{
    font-family:"Trebuchet MS","Comic Sans MS","Segoe UI",sans-serif;
    font-size:clamp(28px, 4vw, 48px);
    line-height:1.08;
    font-weight:900;
    color:var(--ink);
    letter-spacing:-0.04em;
    word-break:break-word;
  }

  .fact .item{
    font-size:clamp(24px, 3vw, 34px);
    font-weight:900;
    letter-spacing:-0.03em;
    margin-top:auto;
  }

  @keyframes slideUp{
    from{
      transform:translateY(80px);
      opacity:0;
    }
    to{
      transform:translateY(0);
      opacity:1;
    }
  }

  .cursor{
    position:fixed;
    left:0;
    top:0;
    width:44px;
    height:44px;
    border-radius:18px;
    background:rgba(245,245,245,.95);
    box-shadow:0 10px 28px rgba(0,0,0,.12);
    pointer-events:none;
    transform:translate(-50%,-50%);
    z-index:999;
    display:flex;
    align-items:center;
    justify-content:center;
    transition:transform .14s cubic-bezier(.18,.9,.22,1);
    will-change:transform,left,top;
    overflow:hidden;
  }

  .cursor::before{
    content:"";
    width:16px;
    height:16px;
    border-radius:6px 12px 12px 6px;
    border:3px solid rgba(50,50,50,.55);
    border-left-color:transparent;
    border-top-color:transparent;
    transform:rotate(-45deg) translateX(-1px);
    display:block;
  }

  .cursor.bounce{
    transition:transform .24s cubic-bezier(.16,1.35,.32,1);
  }

  .hint{
    position:fixed;
    left:16px;
    bottom:16px;
    font-size:12px;
    color:#8b8b8b;
    background:rgba(255,255,255,.7);
    backdrop-filter:blur(8px);
    padding:8px 12px;
    border-radius:999px;
    box-shadow:var(--shadow);
    z-index:5;
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>

<div class="game">
  <div class="header">
    <div class="box">Score: <span id="score">0</span></div>
    <div class="box">Level: <span id="level">1</span></div>
  </div>
  <div class="grid" id="grid"></div>
</div>

<div class="hint">Left click to score • Right click for fact</div>

<script>
  let score = 0;
  let level = 1;
  const items = ["🍞","🥐","🧁","🍩","🍪","🍰"];
  const facts = {
    "🍞":"Bread is one of the oldest prepared foods in human history.",
    "🥐":"The croissant became a bakery icon far beyond its origin story.",
    "🧁":"Cupcakes became popular because they were easy to portion and serve.",
    "🍩":"Doughnuts became famous as a sweet, shareable comfort snack.",
    "🍪":"Cookies became a bakery favorite because they are simple and versatile.",
    "🍰":"Cake is often associated with celebration, making it feel instantly cozy."
  };

  const grid = document.getElementById("grid");
  const cursor = document.getElementById("cursor");
  const scoreEl = document.getElementById("score");
  const levelEl = document.getElementById("level");

  let target = "";
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let curX = mouseX;
  let curY = mouseY;
  let isAnimatingCursor = false;

  function updateUI() {
    scoreEl.textContent = score;
    levelEl.textContent = level;
  }

  function generateGrid() {
    grid.innerHTML = "";

    const count = Math.min(level + 3, items.length);
    const arr = items.slice(0, count);
    target = arr[Math.floor(Math.random() * arr.length)];

    arr.forEach(item => {
      const card = document.createElement("div");
      card.className = "card";
      card.textContent = item;

      card.addEventListener("click", () => {
        if (item === target) {
          score += 10;
          card.classList.add("correct");
          setTimeout(() => card.classList.remove("correct"), 380);
        } else {
          score = Math.max(0, score - 2);
          card.classList.add("wrong");
          setTimeout(() => card.classList.remove("wrong"), 340);
        }
        updateUI();
        setTimeout(generateGrid, 420);
      });

      card.addEventListener("contextmenu", (e) => {
        e.preventDefault();
        showFact(item);
      });

      grid.appendChild(card);
    });
  }

  function showFact(item) {
    const old = document.querySelector(".fact");
    if (old) old.remove();

    const fact = document.createElement("div");
    fact.className = "fact";
    fact.innerHTML = `
      <div class="label">Random Cozy Fact</div>
      <div class="text">${facts[item] || "This item feels cozy, soft, and bakery-perfect."}</div>
      <div class="item">${item}</div>
    `;

    document.body.appendChild(fact);

    setTimeout(() => {
      fact.style.transition = "transform .28s ease, opacity .28s ease";
      fact.style.transform = "translateY(40px)";
      fact.style.opacity = "0";
      setTimeout(() => fact.remove(), 280);
    }, 3200);
  }

  function rotateCardsTowardMouse() {
    const cards = document.querySelectorAll(".card");
    cards.forEach(card => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      const dx = (mouseX - cx) / rect.width;
      const dy = (mouseY - cy) / rect.height;

      const maxTilt = 7;
      const rotY = Math.max(-maxTilt, Math.min(maxTilt, dx * 10));
      const rotX = Math.max(-maxTilt, Math.min(maxTilt, -dy * 10));

      card.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg) translateZ(0)`;
    });

    requestAnimationFrame(rotateCardsTowardMouse);
  }

  function animateCursor() {
    const dx = mouseX - curX;
    const dy = mouseY - curY;

    curX += dx * 0.14;
    curY += dy * 0.14;

    cursor.style.left = curX + "px";
    cursor.style.top = curY + "px";

    const speed = Math.sqrt(dx * dx + dy * dy);
    const scale = 1 + Math.min(speed / 500, 0.14);

    cursor.style.transform = `translate(-50%, -50%) scale(${scale})`;

    requestAnimationFrame(animateCursor);
  }

  document.addEventListener("mousemove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    cursor.classList.add("bounce");
    clearTimeout(window.__cursorBounce);
    window.__cursorBounce = setTimeout(() => cursor.classList.remove("bounce"), 120);
  });

  document.addEventListener("mouseleave", () => {
    cursor.style.opacity = "0";
  });

  document.addEventListener("mouseenter", () => {
    cursor.style.opacity = "1";
  });

  window.addEventListener("resize", () => {
    mouseX = window.innerWidth / 2;
    mouseY = window.innerHeight / 2;
  });

  updateUI();
  generateGrid();
  rotateCardsTowardMouse();
  animateCursor();
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cozy Bakery Pro</title>

<style>
* {
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: "Nunito", sans-serif;
}

body {
  background:#fff;
  overflow:hidden;
  cursor:none; /* HIDE REAL CURSOR */
}

/* CUSTOM CURSOR */
.cursor {
  position:fixed;
  width:50px;
  height:50px;
  border-radius:18px;
  background:#f3f3f3;
  pointer-events:none;
  transform:translate(-50%,-50%);
  z-index:999;
}

/* GAME */
.game {
  width:360px;
  margin:auto;
  margin-top:40px;
}

.header {
  display:flex;
  justify-content:space-between;
  margin-bottom:20px;
}

.box {
  padding:10px 15px;
  border-radius:20px;
  background:white;
  box-shadow:0 4px 10px rgba(0,0,0,0.08);
}

/* GRID */
.grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:15px;
}

/* CARD */
.card {
  height:120px;
  border-radius:20px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:30px;
  background:white;
  box-shadow:0 10px 20px rgba(0,0,0,0.1);
  transition:box-shadow 0.3s;
  transform-style:preserve-3d;
}

/* FEEDBACK */
.correct { animation:pop 0.3s; }
.wrong { animation:shake 0.3s; }

@keyframes pop {
  50% { transform:scale(1.1); }
}

@keyframes shake {
  25% { transform:translateX(-4px); }
  75% { transform:translateX(4px); }
}

/* FACT PANEL */
.fact {
  position:fixed;
  bottom:-10px;
  right:0;
  width:100%;
  height:50vh;
  background:white;
  border-radius:30px 30px 0 0;
  box-shadow:0 -10px 40px rgba(0,0,0,0.2);
  padding:30px;
  font-size:20px;
  font-weight:bold;
  line-height:1.5;
  animation:slideUp 0.4s ease;
}

@keyframes slideUp {
  from { transform:translateY(100%); }
  to { transform:translateY(0); }
}

</style>
</head>

<body>

<div class="cursor" id="cursor"></div>

<div class="game">
  <div class="header">
    <div class="box">Score: <span id="score">0</span></div>
    <div class="box">Level: <span id="level">1</span></div>
  </div>

  <div class="grid" id="grid"></div>
</div>

<script>

/* DATA */
let score = 0;
let level = 1;

const items = ["🍞","🥐","🧁","🍩","🍪","🍰"];

const facts = {
  "🍞":"Bread is one of the oldest prepared foods in human history.",
  "🥐":"Croissants were inspired by Austrian pastries, not France originally.",
  "🧁":"Cupcakes were called 'number cakes' due to easy measurement.",
  "🍩":"Doughnuts were popularized by Dutch settlers in America.",
  "🍪":"Cookies started as small test cakes for oven temperature.",
  "🍰":"Cakes evolved from bread with added honey and nuts."
};

/* GRID */
function generateGrid() {
  const grid = document.getElementById("grid");
  grid.innerHTML = "";

  let count = level + 3;
  let arr = items.slice(0,count);
  let target = arr[Math.floor(Math.random()*arr.length)];
  window.target = target;

  arr.forEach(item=>{
    let card = document.createElement("div");
    card.className = "card";
    card.innerText = item;

    card.onclick = ()=>clickCard(card,item);
    card.oncontextmenu = (e)=>{
      e.preventDefault();
      showFact(item);
    };

    grid.appendChild(card);
  });
}

/* CLICK */
function clickCard(el,item) {
  if(item === target){
    score += 10;
    el.classList.add("correct");
  } else {
    score -= 2;
    el.classList.add("wrong");
  }

  document.getElementById("score").innerText = score;

  setTimeout(generateGrid,400);
}

/* FACT PANEL */
function showFact(item) {
  let old = document.querySelector(".fact");
  if(old) old.remove();

  let div = document.createElement("div");
  div.className = "fact";
  div.innerText = facts[item];

  document.body.appendChild(div);

  setTimeout(()=>div.remove(),4000);
}

/* STABLE 3D ROTATION */
document.addEventListener("mousemove",(e)=>{
  document.querySelectorAll(".card").forEach(card=>{
    let rect = card.getBoundingClientRect();

    let x = (e.clientX - rect.left) / rect.width - 0.5;
    let y = (e.clientY - rect.top) / rect.height - 0.5;

    card.style.transform = `
      rotateY(${x*8}deg)
      rotateX(${-y*8}deg)
    `;
  });
});

/* SMOOTH CURSOR WITH BOUNCE */
const cursor = document.getElementById("cursor");

let x = 0, y = 0;
let tx = 0, ty = 0;

document.addEventListener("mousemove",(e)=>{
  tx = e.clientX;
  ty = e.clientY;
});

function animateCursor(){
  x += (tx - x) * 0.2;
  y += (ty - y) * 0.2;

  cursor.style.left = x + "px";
  cursor.style.top = y + "px";

  requestAnimationFrame(animateCursor);
}

animateCursor();

/* INIT */
generateGrid();

</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Perspective Anime Reflective Card</title>
    <style>
        /* --- Global Setup --- */
        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-color: #ffffff; /* Pure white background */
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            overflow: hidden; 
            
            /* Hides the default computer cursor so we can use our custom bouncy one */
            cursor: none !important; 
            user-select: none; /* Prevents accidental text selection while dragging */
        }

        /* --- Main Layout Wrapper --- */
        .main-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100vw;
            height: 100vh;
        }

        /* --- 3D Scene Wrapper --- */
        .scene {
            perspective: 1500px;
            /* EXTENDED PADDING: Prevents the shadow from being cut off at steep angles */
            padding: 150px; 
            z-index: 10;
        }

        /* --- The Card --- */
        .card {
            width: 280px;
            height: 400px;
            background-color: #ffffff;
            border-radius: 20px;
            
            /* Enhanced, smoother shadow that bleeds out further */
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15); 
            border: 1px solid #e0e0e0; 
            
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden; 
            
            transform-style: preserve-3d;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* --- State when PNG is added --- */
        .card.has-image {
            background-color: transparent; 
            border: none;
            background-size: 100% 100%; 
        }

        /* --- The Plus Icon --- */
        .plus-icon {
            font-size: 72px;
            font-weight: 300;
            color: #cccccc;
            transition: color 0.3s ease, transform 0.3s ease;
            pointer-events: none;
            z-index: 2;
        }

        /* --- Flat Anime-Style Rectangle Glare --- */
        .glare {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            
            background: linear-gradient(
                105deg,
                transparent 0%,
                transparent 42%,
                rgba(255, 255, 255, 0.15) 42%, 
                rgba(255, 255, 255, 0.15) 55%, 
                transparent 55%,
                transparent 100%
            );
            background-size: 250% 250%;
            background-position: 50% 50%;
            opacity: 0;
            pointer-events: none; 
            transition: opacity 0.5s ease;
            z-index: 1;
        }

        .card.has-image .glare {
            opacity: 1; 
        }

        /* --- NEW: Right Side UI Panel --- */
        .right-panel {
            background-color: #000000; /* Black / Blank UI color */
            border-radius: 30px; /* All corners rounded */
            width: 0;
            opacity: 0;
            overflow: hidden;
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            z-index: 20;
        }

        .right-panel.active {
            width: 340px;
            opacity: 1;
            padding: 40px;
            margin-left: 30px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.25);
        }

        .right-panel-content {
            width: 100%;
            min-width: 260px; /* Maintains structure during width transition */
            display: flex;
            flex-direction: column;
            align-items: center;
            opacity: 0;
            transition: opacity 0.4s ease;
            transition-delay: 0.2s; /* Fades in smoothly */
        }

        .right-panel.active .right-panel-content {
            opacity: 1;
        }

        .type-prompt {
            color: #ffffff;
            font-size: 14px;
            font-weight: 800; /* Bold */
            margin-bottom: 20px;
            text-align: center;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        /* Loading bar container */
        .bar-container {
            width: 100%;
            height: 24px;
            background-color: #2a2a2a;
            border-radius: 50px; /* Rounded corners */
            margin-bottom: 30px;
            overflow: hidden;
            box-shadow: inset 0 4px 8px rgba(0,0,0,0.5);
            border: 2px solid #333;
        }

        /* Loading bar fill */
        .bar-fill {
            height: 100%;
            width: 0%;
            border-radius: 50px; /* Rounded corners */
            transition: width 0.1s linear, background-color 0.4s ease;
        }

        /* Text Input */
        .curvy-text-input {
            width: 100%;
            padding: 16px 20px;
            border-radius: 50px; /* Curvy Edges */
            border: 2px solid #333;
            outline: none;
            background-color: #1a1a1a;
            color: #ffffff;
            font-family: inherit;
            font-weight: 800; /* Bold font */
            font-size: 16px;
            text-align: center;
            box-sizing: border-box;
            transition: border-color 0.3s ease, background-color 0.3s ease;
            
            /* Ensures user can click and type inside */
            user-select: auto;
            -webkit-user-select: auto;
            cursor: none !important; 
        }

        .curvy-text-input:focus {
            border-color: #ffffff;
            background-color: #222222;
        }
        
        .curvy-text-input::placeholder {
            color: #666;
            font-weight: 600;
        }

        /* --- Custom Bouncy Cursor Mascot --- */
        .custom-cursor {
            position: fixed;
            top: 0; 
            left: 0;
            width: 40px;
            height: 40px;
            pointer-events: none; 
            z-index: 9999;
            transform-origin: top left; 
            transition: opacity 0.2s ease;
        }
    </style>
</head>
<body>

    <!-- Our Custom Mascot Cursor -->
    <div class="custom-cursor" id="cursor">
        <svg width="44" height="44" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g filter="url(#drop-shadow)">
                <path d="M2 2 L22 9 L13 13 L9 22 Z" fill="white" stroke="#2b2b2b" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
            </g>
            <defs>
                <filter id="drop-shadow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="1" dy="4" stdDeviation="3" flood-color="#000000" flood-opacity="0.25"/>
                </filter>
            </defs>
        </svg>
    </div>

    <div class="main-wrapper">
        <div class="scene">
            <div class="card" id="upload-card" title="Left Click to Upload | Right Click & Drag to Rotate">
                <div class="plus-icon" id="plus-icon">+</div>
                <div class="glare" id="glare"></div>
            </div>
        </div>

        <!-- Right Side Upload Panel -->
        <div class="right-panel" id="right-panel">
            <div class="right-panel-content">
                <div class="type-prompt">Rotate To Load</div>
                <div class="bar-container">
                    <div class="bar-fill" id="loading-bar-fill"></div>
                </div>
                <!-- Interactive Typing Element -->
                <input type="text" class="curvy-text-input" id="curvy-text-input" placeholder="Type Card Info..." autocomplete="off">
            </div>
        </div>
    </div>

    <!-- Hidden File Input -->
    <input type="file" id="file-input" accept=".png, image/png" style="display: none;">

    <script>
        const card = document.getElementById('upload-card');
        const fileInput = document.getElementById('file-input');
        const plusIcon = document.getElementById('plus-icon');
        const glare = document.getElementById('glare');
        const cursor = document.getElementById('cursor');
        
        // Right panel variables
        const rightPanel = document.getElementById('right-panel');
        const loadingBarFill = document.getElementById('loading-bar-fill');
        const textInput = document.getElementById('curvy-text-input');

        // --- 1. Custom Cursor Spring Physics ---
        let mouseX = 0, mouseY = 0;
        let cursorX = 0, cursorY = 0;
        let cursorVX = 0, cursorVY = 0;
        const stiffness = 0.12; 
        const damping = 0.65;   

        window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
        });

        document.addEventListener('mouseleave', () => cursor.style.opacity = '0');
        document.addEventListener('mouseenter', () => cursor.style.opacity = '1');

        // --- 2. Card Image Upload Logic ---
        card.addEventListener('click', (e) => {
            if (e.button === 0) {
                fileInput.click();
            }
        });

        fileInput.addEventListener('change', (event) => {
            const file = event.target.files[0];
            if (file && file.type === 'image/png') {
                const reader = new FileReader();
                reader.onload = (e) => {
                    card.style.backgroundImage = `url('${e.target.result}')`;
                    plusIcon.style.display = 'none';
                    card.classList.add('has-image');
                    
                    // --- Activate/Update Right UI ---
                    rightPanel.classList.add('active');
                    
                    // Reset Logic on every new PNG
                    totalRotation = 0;
                    loadingBarFill.style.width = '0%';
                    textInput.value = '';
                    
                    // Generate a totally random RGB
                    const r = Math.floor(Math.random() * 256);
                    const g = Math.floor(Math.random() * 256);
                    const b = Math.floor(Math.random() * 256);
                    loadingBarFill.style.backgroundColor = `rgb(${r}, ${g}, ${b})`;
                };
                reader.readAsDataURL(file);
            } else if (file) {
                alert("Please select a valid PNG file!");
            }
            fileInput.value = '';
        });

        // --- 3. 3D Interaction Engine ---
        let isHovering = false;
        let isDragging = false;
        let hasDragged = false; // Tracks if user has ever interacted
        
        let currentRX = 0, currentRY = 0, currentRZ = 0;
        let targetRX = 0, targetRY = 0, targetRZ = 0;
        let lastRX = 0, lastRY = 0;
        
        let dragStartX = 0, dragStartY = 0;
        let dragStartRX = 0, dragStartRY = 0, dragStartRZ = 0;
        
        let hoverTime = 0; 
        let totalRotation = 0; // Tracks cummulative dragging

        window.addEventListener('contextmenu', e => e.preventDefault());

        card.addEventListener('mouseenter', () => isHovering = true);
        card.addEventListener('mouseleave', () => isHovering = false);

        // Start Right Click Drag
        window.addEventListener('mousedown', (e) => {
            if (e.button === 2) { 
                isDragging = true;
                hasDragged = true; // Permanently disables auto-hover rotation snapping
                dragStartX = e.clientX;
                dragStartY = e.clientY;
                
                dragStartRX = currentRX;
                dragStartRY = currentRY;
                dragStartRZ = currentRZ;
                
                cursor.style.transform = `translate(${cursorX}px, ${cursorY}px) scale(0.8)`; 
            }
        });

        // End Right Click Drag
        window.addEventListener('mouseup', (e) => {
            if (e.button === 2) {
                isDragging = false;
            }
        });

        // --- 4. Main Animation Loop ---
        function animate() {
            // -- Cursor Physics --
            let ax = (mouseX - cursorX) * stiffness;
            let ay = (mouseY - cursorY) * stiffness;
            cursorVX += ax;
            cursorVY += ay;
            cursorVX *= damping;
            cursorVY *= damping;
            cursorX += cursorVX;
            cursorY += cursorVY;
            
            if (!isDragging) {
                cursor.style.transform = `translate(${cursorX}px, ${cursorY}px)`;
            } else {
                cursor.style.transform = `translate(${cursorX}px, ${cursorY}px) scale(0.8)`;
            }

            // -- Card 3D Physics --
            if (isDragging) {
                let deltaX = mouseX - dragStartX;
                let deltaY = mouseY - dragStartY;
                
                // Enhanced Steering: Higher multiplier reduces sluggish resistance
                targetRY = dragStartRY + deltaX * 0.8;
                targetRX = dragStartRX - deltaY * 0.8;
                targetRZ = dragStartRZ - (deltaX * 0.15) - (deltaY * 0.15); 

                card.style.boxShadow = `0 45px 80px rgba(0, 0, 0, 0.3)`;
            } 
            else if (isHovering && !hasDragged) {
                // Initial life animation (Only runs BEFORE you touch it)
                hoverTime += 0.02;
                targetRX = Math.sin(hoverTime) * 15;
                targetRY = Math.cos(hoverTime * 1.2) * 18;
                targetRZ = Math.sin(hoverTime * 0.8) * 5;
                card.style.boxShadow = `0 30px 50px rgba(0, 0, 0, 0.2)`;
            } 
            else {
                // If the user has dragged and released, DO NOT snap targets to 0! 
                // They stay anchored to exactly where they were left.
                card.style.boxShadow = `0 20px 40px rgba(0, 0, 0, 0.15)`;
            }

            // Enhanced Steering Lerp: 0.25 (Catch up faster, feels far more responsive)
            currentRX += (targetRX - currentRX) * 0.25;
            currentRY += (targetRY - currentRY) * 0.25;
            currentRZ += (targetRZ - currentRZ) * 0.25;

            // Apply transforms
            card.style.transform = `rotateX(${currentRX}deg) rotateY(${currentRY}deg) rotateZ(${currentRZ}deg)`;

            // -- Glare Mapping --
            let bgX = 50 - (currentRY * 1.5);
            let bgY = 50 - (currentRX * 1.5);
            bgX = Math.max(-50, Math.min(150, bgX));
            bgY = Math.max(-50, Math.min(150, bgY));
            glare.style.backgroundPosition = `${bgX}% ${bgY}%`;

            // -- Loading Bar Calculation --
            // Adds up physical distance rotated to continuously push the loading bar
            if (rightPanel.classList.contains('active')) {
                let frameDiff = Math.abs(currentRX - lastRX) + Math.abs(currentRY - lastRY);
                totalRotation += frameDiff;
                
                // Maps 1000 total cumulative degree-ticks into 100% width
                let fillPercent = Math.min(100, (totalRotation / 1000) * 100);
                loadingBarFill.style.width = fillPercent + '%';
            }

            lastRX = currentRX;
            lastRY = currentRY;

            requestAnimationFrame(animate);
        }

        animate();
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cozy Bakery Game</title>

<style>

/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Segoe UI', sans-serif;
}

body {
  background: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* CONTAINER */
.game {
  width: 360px;
  padding: 20px;
}

/* HEADER */
.header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

.score, .level {
  background: #fff;
  padding: 10px 16px;
  border-radius: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08);
  font-size: 14px;
}

/* CARD GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
}

/* CARDS */
.card {
  height: 120px;
  border-radius: 20px;
  background: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30px;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(.25,.8,.25,1);
  box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  transform-style: preserve-3d;
}

/* HOVER 3D */
.card:hover {
  transform: rotateY(10deg) rotateX(10deg) scale(1.05);
}

/* ACTIVE PRESS */
.card:active {
  transform: scale(0.95);
}

/* SUCCESS */
.correct {
  animation: pop 0.4s ease;
  box-shadow: 0 0 20px rgba(0,200,100,0.4);
}

/* WRONG */
.wrong {
  animation: shake 0.4s;
}

/* ANIMATIONS */
@keyframes pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

@keyframes shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  50% { transform: translateX(5px); }
  75% { transform: translateX(-5px); }
  100% { transform: translateX(0); }
}

/* FLOAT SCORE */
.float {
  position: absolute;
  color: green;
  font-size: 14px;
  animation: floatUp 1s forwards;
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-20px); }
}

/* BUTTON */
button {
  margin-top: 20px;
  width: 100%;
  padding: 12px;
  border-radius: 20px;
  border: none;
  background: #f5f5f5;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  background: #eaeaea;
}

</style>
</head>

<body>

<div class="game">

<div class="header">
<div class="score">Score: <span id="score">0</span></div>
<div class="level">Level: <span id="level">1</span></div>
</div>

<div class="grid" id="grid"></div>

<button onclick="nextLevel()">Next Level</button>

</div>

<script>

let score = 0;
let level = 1;

const items = [
  "🍞","🥐","🧁","🍩",
  "🍪","🍰","🥨","🍕"
];

function generateGrid() {
  const grid = document.getElementById("grid");
  grid.innerHTML = "";

  let count = level + 3;
  let selected = items.slice(0, count);

  let target = selected[Math.floor(Math.random() * selected.length)];

  selected.forEach(item => {
    let div = document.createElement("div");
    div.className = "card";
    div.innerText = item;

    div.onclick = () => handleClick(div, item, target);

    grid.appendChild(div);
  });

  window.targetItem = target;
}

function handleClick(el, item, target) {
  if (item === target) {
    score += 10;
    updateScore();

    el.classList.add("correct");
    showFloat("+10", el);

    setTimeout(generateGrid, 500);
  } else {
    el.classList.add("wrong");
    score -= 2;
    updateScore();
  }
}

function updateScore() {
  document.getElementById("score").innerText = score;
}

function nextLevel() {
  if (level < 3) {
    level++;
    document.getElementById("level").innerText = level;
    generateGrid();
  } else {
    alert("Max Level Reached!");
  }
}

function showFloat(text, el) {
  let span = document.createElement("span");
  span.className = "float";
  span.innerText = text;

  let rect = el.getBoundingClientRect();

  span.style.left = rect.left + "px";
  span.style.top = rect.top + "px";

  document.body.appendChild(span);

  setTimeout(() => span.remove(), 1000);
}

generateGrid();

</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flashcard Widget</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f5f4f0;
    --card-bg: #ffffff;
    --card-shadow: 0 2px 8px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.05);
    --card-hover-shadow: 0 8px 30px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.07);
    --text-primary: #1a1a1a;
    --text-muted: #9a9a8e;
    --accent: #e8845a;
    --accent-light: #fdf0ea;
    --radius: 16px;
    --card-w: 200px;
    --card-h: 260px;
  }

  body {
    background: var(--bg);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Subtle paper texture */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(232,132,90,0.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(100,130,200,0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .scene {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100vw;
    height: 100vh;
  }

  /* Stack container — cards pile up here */
  .stack-wrapper {
    position: relative;
    width: var(--card-w);
    height: var(--card-h);
  }

  /* Base card (the + trigger) */
  .add-card {
    position: absolute;
    inset: 0;
    width: var(--card-w);
    height: var(--card-h);
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--card-shadow);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: box-shadow 0.25s ease, transform 0.2s ease;
    user-select: none;
    z-index: 1;
    border: 1.5px dashed rgba(0,0,0,0.1);
  }

  .add-card:hover {
    box-shadow: var(--card-hover-shadow);
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .add-card:active {
    transform: translateY(0px) scale(0.98);
  }

  .plus-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }

  .add-card:hover .plus-circle {
    background: var(--accent);
    transform: rotate(90deg) scale(1.1);
  }

  .plus-circle svg {
    width: 20px;
    height: 20px;
    stroke: var(--accent);
    stroke-width: 2.5;
    transition: stroke 0.2s;
  }

  .add-card:hover .plus-circle svg {
    stroke: #fff;
  }

  .add-label {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .add-card:hover .add-label {
    color: var(--accent);
  }

  /* ── Stacked flash cards ── */
  .flash-card {
    position: absolute;
    width: var(--card-w);
    height: var(--card-h);
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--card-shadow);
    padding: 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    cursor: default;
    /* start off-screen right, then animate in */
    transform: translateX(60px) translateY(20px) rotate(6deg);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease, box-shadow 0.2s;
    pointer-events: none;
  }

  .flash-card.placed {
    opacity: 1;
    pointer-events: auto;
  }

  /* Each successive card offsets slightly right + small rotation */
  .flash-card:hover {
    box-shadow: var(--card-hover-shadow);
    z-index: 999 !important;
    transform: none !important;
  }

  /* Card inner content */
  .card-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-light);
    display: inline-block;
    padding: 3px 8px;
    border-radius: 20px;
    width: fit-content;
  }

  .card-title {
    font-family: 'Lora', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .card-body {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .card-num {
    font-size: 10px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.5;
  }

  /* counter badge above stack */
  .counter {
    position: absolute;
    top: -32px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    transition: opacity 0.3s;
    font-weight: 400;
  }

  .counter.hidden { opacity: 0; }
</style>
</head>
<body>

<div class="scene">
  <div class="stack-wrapper" id="stackWrapper">
    <div class="counter hidden" id="counter">0 cards</div>

    <!-- Add card trigger -->
    <div class="add-card" id="addCard" onclick="createCard()">
      <div class="plus-circle">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </div>
      <span class="add-label">New card</span>
    </div>
  </div>
</div>

<script>
  const cardData = [
    { tag: "Design", title: "Visual Hierarchy", body: "Arrange elements so readers naturally flow toward the most important content first." },
    { tag: "Type", title: "Serif vs Sans", body: "Serifs feel editorial and warm. Sans-serifs read clean and modern. Mix both intentionally." },
    { tag: "Color", title: "60-30-10 Rule", body: "60% dominant, 30% secondary, 10% accent. A simple formula for balanced palettes." },
    { tag: "Layout", title: "Grid Systems", body: "Invisible columns create invisible order. Break them deliberately for emphasis." },
    { tag: "Motion", title: "Easing Curves", body: "ease-in for exits, ease-out for entrances. Never use linear — nothing in nature moves linearly." },
    { tag: "Space", title: "Negative Space", body: "What you leave out is as powerful as what you put in. Let things breathe." },
    { tag: "UX", title: "Fitts's Law", body: "Larger targets that are closer are faster to click. Size your buttons accordingly." },
    { tag: "Gestalt", title: "Proximity", body: "Elements near each other are perceived as related. Use spacing to group meaning." },
  ];

  let cardCount = 0;
  const wrapper = document.getElementById('stackWrapper');
  const addCard = document.getElementById('addCard');
  const counter = document.getElementById('counter');

  function createCard() {
    const data = cardData[cardCount % cardData.length];
    cardCount++;

    const card = document.createElement('div');
    card.className = 'flash-card';

    // Stack offset: each card nudges right and slightly rotates
    const offsetX = cardCount * 6;
    const offsetY = cardCount * -3;
    const rotate = (cardCount % 2 === 0 ? 1 : -1) * (cardCount * 1.2);
    const zIndex = cardCount + 1;

    card.style.zIndex = zIndex;
    // Final resting position
    const finalTransform = `translateX(${offsetX}px) translateY(${offsetY}px) rotate(${rotate}deg)`;

    card.innerHTML = `
      <div class="card-tag">${data.tag}</div>
      <div class="card-title">${data.title}</div>
      <div class="card-body">${data.body}</div>
      <div class="card-footer">
        <span class="card-num">#${String(cardCount).padStart(2,'0')}</span>
        <div class="card-dot"></div>
      </div>
    `;

    // Insert before the add-card so it sits behind it visually while animating
    wrapper.insertBefore(card, addCard);

    // Trigger fly-in animation
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        card.style.transform = finalTransform;
        card.classList.add('placed');
      });
    });

    // Raise add-card z-index above all stacked cards
    addCard.style.zIndex = cardCount + 10;

    // Update counter
    counter.classList.remove('hidden');
    counter.textContent = cardCount === 1 ? '1 card' : `${cardCount} cards`;
  }
</script>
</body>
</html>
